FROM rockylinux:9

RUN dnf install -y openssh-server sudo rsync ca-certificates \
    && dnf clean all \
    && ssh-keygen -A \
    && useradd -m -s /bin/bash kdeploy \
    && echo 'kdeploy ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/kdeploy \
    && chmod 440 /etc/sudoers.d/kdeploy

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 22
ENTRYPOINT ["/entrypoint.sh"]
